{
  "cli": {
    "version": ">= 16.18.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "qa-release": {
      "distribution": "internal",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "qa-agent": {
      "distribution": "internal",
      "environment": "preview",
      "android": {
        "buildType": "apk",
        "config": "qa-agent-android.yml"
      }
    },
    "production": {
      "environment": "production"
    }
  }
}
